# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
APP_URL=

# PORT: The port the server runs on (defaults to 3000)
PORT=3000

# JWT_SECRET: Security token signature string for authentication
JWT_SECRET=

# SMTP settings for real OTP Email Delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# BASEROW DATABASE INTEGRATION
BASEROW_API_TOKEN=
BASEROW_TABLE_URL=
BASEROW_BASE_URL=

# DATABASE SETTINGS (MySQL VPS Integration - Fallback to virtual JSON DB if empty)
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_DATABASE=
DB_NAME=
DB_PORT=3305

# ENVIRONMENT SETTINGS
NODE_ENV=development
DISABLE_HMR=false
